generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String         @db.Text
  slogan        String?
  logo          String?
  theme         String?
  active        Boolean        @default(true)

  registrations Registration[]
  events        Event[]
  gallery       GalleryImage[]
  volunteers    Volunteer[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  @@map("projects")
}

model Registration {
  id        String   @id @default(cuid())

  name      String
  email     String?
  phone     String
  age       Int?
  city      String?
  neighborhood String?
  message   String? @db.Text

  status    RegistrationStatus @default(PENDING)

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@map("registrations")
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  location    String?
  date        DateTime

  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  attendances EventAttendance[]
}

model Unit {
  id        String   @id @default(cuid())
  name      String
  address   String
  city      String
  state     String
  latitude  Float
  longitude Float
  whatsapp  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([city, state])
  @@map("units")
}

model Volunteer {
  id          String            @id @default(cuid())
  name        String
  email       String            @unique
  phone       String
  password    String
  projectId   String?
  project     Project?          @relation(fields: [projectId], references: [id])
  attendances EventAttendance[]
  certificates Certificate[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  @@map("volunteers")
}

model EventAttendance {
  id          String    @id @default(cuid())
  eventId     String
  volunteerId String
  presentAt   DateTime  @default(now())
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  @@unique([eventId, volunteerId])
  @@map("event_attendances")
}

model Certificate {
  id          String    @id @default(cuid())
  title       String
  issuedAt    DateTime  @default(now())
  fileUrl     String?
  volunteerId String
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  @@index([volunteerId])
  @@map("certificates")
}

model GalleryImage {
  id        String @id @default(cuid())
  imageUrl  String
  alt       String?

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

enum RegistrationStatus {
  PENDING
  CONTACTED
  APPROVED
  REJECTED
}
